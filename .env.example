NODE_ENV=production
PORT=3001
FRONTEND_URL=https://splitpay.vercel.app
APP_BASE_URL=https://api.splitpay.id

DATABASE_URL=postgresql://user:password@host:5432/splitpay_db
REDIS_URL=redis://default:password@host:6379

JWT_ACCESS_SECRET=<min_64_char_random_hex>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=<min_64_char_random_hex_berbeda>
JWT_REFRESH_EXPIRES_IN=7d

OTP_EXPIRES_IN_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_COOLDOWN_SECONDS=60

SIGNED_URL_SECRET=<min_64_char_random_hex>
SIGNED_URL_EXPIRES_IN_HOURS=72

RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@splitpay.id
MAIL_FROM=noreply@splitpay.id
FONNTE_TOKEN=<fonnte_token>

VAPID_PUBLIC_KEY=Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_SUBJECT=mailto:admin@splitpay.id

PAYMENT_WEBHOOK_SECRET=<secret_dari_payment_gateway>
DEFAULT_PAYMENT_PROVIDER=MIDTRANS
MIDTRANS_SERVER_KEY=<midtrans_server_key>
MIDTRANS_CLIENT_KEY=<midtrans_client_key>
MIDTRANS_IS_PRODUCTION=false
XENDIT_SECRET_KEY=<xendit_secret_key>
XENDIT_WEBHOOK_TOKEN=<xendit_webhook_token>

THROTTLE_TTL=60
THROTTLE_LIMIT=60
TZ=Asia/Jakarta
